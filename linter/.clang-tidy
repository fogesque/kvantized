# =============================================================================
# clang-tidy configuration
# Based on Google style with project-specific overrides from CODESTYLE.md
# =============================================================================

# -----------------------------------------------------------------------------
# Enabled checks
# -----------------------------------------------------------------------------
# Base: Google checks
# Additional: bugprone, performance, cppcoreguidelines, cert, clang-analyzer,
#             readability, modernize, misc
# Project overrides from CODESTYLE.md take priority over Google defaults
# -----------------------------------------------------------------------------

Checks: >
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  google-*,
  misc-*,
  modernize-*,
  performance-*,
  readability-*,
  -modernize-use-trailing-return-type,
  -google-readability-todo,
  -readability-else-after-return,
  -cppcoreguidelines-avoid-magic-numbers,
  -google-build-using-namespace,
  -modernize-avoid-c-arrays,
  -cppcoreguidelines-avoid-c-arrays,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-constant-array-index,
  -cppcoreguidelines-prefer-member-initializer,
  -misc-include-cleaner,
  -cert-env33-c

WarningsAsErrors: >
  readability-braces-around-statements,
  readability-magic-numbers,
  readability-identifier-naming,
  readability-function-size,
  modernize-use-auto,
  modernize-loop-convert,
  modernize-make-shared,
  modernize-make-unique,
  bugprone-exception-escape,
  misc-const-correctness

HeaderFilterRegex: '.*\.hpp$'

FormatStyle: file

# =============================================================================
# Check options
# =============================================================================

CheckOptions:
  # ---------------------------------------------------------------------------
  # CS-02: readability-magic-numbers
  # Only 0 and 1 are allowed without naming (strictest mode)
  # ---------------------------------------------------------------------------
  - key: readability-magic-numbers.IgnoredIntegerValues
    value: '0;1'
  - key: readability-magic-numbers.IgnoredFloatingPointValues
    value: '0.0;1.0'
  - key: readability-magic-numbers.IgnoreAllFloatingPointValues
    value: 'false'
  - key: readability-magic-numbers.IgnoreBitFieldsWidths
    value: 'true'
  - key: readability-magic-numbers.IgnorePowersOf2IntegerValues
    value: 'false'
  - key: readability-magic-numbers.IgnoreTypeAliases
    value: 'false'

  # ---------------------------------------------------------------------------
  # CS-04: readability-function-size
  # Max 60 lines, max 3 parameters (from CODESTYLE.md)
  # ---------------------------------------------------------------------------
  - key: readability-function-size.LineThreshold
    value: '60'
  - key: readability-function-size.StatementThreshold
    value: '40'
  - key: readability-function-size.BranchThreshold
    value: '10'
  - key: readability-function-size.ParameterThreshold
    value: '3'
  - key: readability-function-size.NestingThreshold
    value: '4'

  # ---------------------------------------------------------------------------
  # readability-function-cognitive-complexity
  # Standard threshold of 25
  # ---------------------------------------------------------------------------
  - key: readability-function-cognitive-complexity.Threshold
    value: '25'
  - key: readability-function-cognitive-complexity.DescribeBasicIncrements
    value: 'true'
  - key: readability-function-cognitive-complexity.IgnoreMacros
    value: 'true'

  # ---------------------------------------------------------------------------
  # CS-05: readability-identifier-length
  # Min 2 characters, with exceptions for loop counters (i, j, k, n, x, y, z)
  # ---------------------------------------------------------------------------
  - key: readability-identifier-length.MinimumVariableNameLength
    value: '2'
  - key: readability-identifier-length.MinimumParameterNameLength
    value: '2'
  - key: readability-identifier-length.MinimumLoopCounterNameLength
    value: '1'
  - key: readability-identifier-length.IgnoredVariableNames
    value: '^[ijknxyz]$'
  - key: readability-identifier-length.IgnoredParameterNames
    value: '^[ijknxyz]$'
  - key: readability-identifier-length.IgnoredLoopCounterNames
    value: '^[ijknxyz]$'

  # ---------------------------------------------------------------------------
  # CS-02: readability-braces-around-statements
  # Mandatory braces for all control structures (CODESTYLE.md)
  # ---------------------------------------------------------------------------
  - key: readability-braces-around-statements.ShortStatementLines
    value: '0'

  # ---------------------------------------------------------------------------
  # CS-02: modernize-use-auto
  # Use auto everywhere possible (CODESTYLE.md)
  # ---------------------------------------------------------------------------
  - key: modernize-use-auto.MinTypeNameLength
    value: '1'
  - key: modernize-use-auto.RemoveStars
    value: 'false'

  # ---------------------------------------------------------------------------
  # CS-02: modernize-loop-convert
  # Range-based for instead of index-based loops (CODESTYLE.md)
  # ---------------------------------------------------------------------------
  - key: modernize-loop-convert.MinConfidence
    value: 'reasonable'
  - key: modernize-loop-convert.NamingStyle
    value: 'camelBack'

  # ---------------------------------------------------------------------------
  # CS-02: misc-const-correctness
  # Enforce const for non-modified variables (CODESTYLE.md)
  # ---------------------------------------------------------------------------
  - key: misc-const-correctness.AnalyzeValues
    value: 'true'
  - key: misc-const-correctness.AnalyzeReferences
    value: 'true'
  - key: misc-const-correctness.WarnPointersAsValues
    value: 'false'
  - key: misc-const-correctness.TransformValues
    value: 'true'
  - key: misc-const-correctness.TransformReferences
    value: 'true'

  # ---------------------------------------------------------------------------
  # CS-04: modernize-make-shared / modernize-make-unique
  # Smart pointers instead of raw new/delete (CODESTYLE.md)
  # ---------------------------------------------------------------------------
  - key: modernize-make-shared.IgnoreMacros
    value: 'true'
  - key: modernize-make-unique.IgnoreMacros
    value: 'true'

  # ---------------------------------------------------------------------------
  # CS-05: readability-identifier-naming
  # Full naming configuration per CODESTYLE.md
  # ---------------------------------------------------------------------------

  # --- Namespaces: lower_case (e.g. fight, network, policy) ---
  - key: readability-identifier-naming.NamespaceCase
    value: 'lower_case'

  # --- Types: PascalCase (classes, structs, enums, type aliases) ---
  - key: readability-identifier-naming.ClassCase
    value: 'CamelCase'
  - key: readability-identifier-naming.StructCase
    value: 'CamelCase'
  - key: readability-identifier-naming.EnumCase
    value: 'CamelCase'
  - key: readability-identifier-naming.TypeAliasCase
    value: 'CamelCase'
  - key: readability-identifier-naming.TypedefCase
    value: 'CamelCase'
  - key: readability-identifier-naming.TemplateParameterCase
    value: 'CamelCase'
  - key: readability-identifier-naming.UnionCase
    value: 'CamelCase'

  # --- Abstract class (interface) prefix: I ---
  - key: readability-identifier-naming.AbstractClassCase
    value: 'CamelCase'
  - key: readability-identifier-naming.AbstractClassPrefix
    value: 'I'

  # --- Enum constants: PascalCase ---
  - key: readability-identifier-naming.EnumConstantCase
    value: 'CamelCase'

  # --- Public methods: PascalCase ---
  - key: readability-identifier-naming.PublicMethodCase
    value: 'CamelCase'

  # --- Private methods: camelCase ---
  - key: readability-identifier-naming.PrivateMethodCase
    value: 'camelBack'

  # --- Protected methods: camelCase ---
  - key: readability-identifier-naming.ProtectedMethodCase
    value: 'camelBack'

  # --- Public member variables: camelCase (no prefix/suffix per CODESTYLE.md) ---
  - key: readability-identifier-naming.PublicMemberCase
    value: 'camelBack'
  - key: readability-identifier-naming.PublicMemberPrefix
    value: ''
  - key: readability-identifier-naming.PublicMemberSuffix
    value: ''

  # --- Private member variables: camelCase (no prefix/suffix per CODESTYLE.md) ---
  - key: readability-identifier-naming.PrivateMemberCase
    value: 'camelBack'
  - key: readability-identifier-naming.PrivateMemberPrefix
    value: ''
  - key: readability-identifier-naming.PrivateMemberSuffix
    value: ''

  # --- Protected member variables: camelCase ---
  - key: readability-identifier-naming.ProtectedMemberCase
    value: 'camelBack'
  - key: readability-identifier-naming.ProtectedMemberPrefix
    value: ''
  - key: readability-identifier-naming.ProtectedMemberSuffix
    value: ''

  # --- Static member variables: PascalCase (global-like names per CS-06) ---
  - key: readability-identifier-naming.ClassMemberCase
    value: 'camelBack'

  # --- Local variables: camelCase ---
  - key: readability-identifier-naming.LocalVariableCase
    value: 'camelBack'

  # --- Function parameters: camelCase ---
  - key: readability-identifier-naming.ParameterCase
    value: 'camelBack'

  # --- Global/namespace functions: PascalCase (per CS-06) ---
  - key: readability-identifier-naming.FunctionCase
    value: 'CamelCase'

  # --- Global/namespace variables: PascalCase (per CS-06) ---
  - key: readability-identifier-naming.GlobalVariableCase
    value: 'CamelCase'

  # --- Global/namespace constants: PascalCase (per CS-06) ---
  - key: readability-identifier-naming.GlobalConstantCase
    value: 'CamelCase'
  - key: readability-identifier-naming.StaticConstantCase
    value: 'CamelCase'

  # --- Local constants: camelCase (per CS-02 examples: constexpr auto maxSize = 1024) ---
  - key: readability-identifier-naming.LocalConstantCase
    value: 'camelBack'
  - key: readability-identifier-naming.LocalConstantPointerCase
    value: 'camelBack'

  # --- Constexpr functions: PascalCase ---
  - key: readability-identifier-naming.ConstexprFunctionCase
    value: 'CamelCase'

  # --- Static methods: PascalCase (factory methods, pure functions per CS-01) ---
  - key: readability-identifier-naming.ClassMethodCase
    value: 'CamelCase'

  # --- Macro naming: UPPER_CASE ---
  - key: readability-identifier-naming.MacroDefinitionCase
    value: 'UPPER_CASE'

  # ---------------------------------------------------------------------------
  # CS-02: Exception-related checks (no exceptions policy)
  # ---------------------------------------------------------------------------
  - key: bugprone-exception-escape.FunctionsThatShouldNotThrow
    value: ''
  - key: bugprone-exception-escape.IgnoredExceptions
    value: ''

  # ---------------------------------------------------------------------------
  # Performance checks
  # ---------------------------------------------------------------------------
  - key: performance-move-const-arg.CheckTriviallyCopyableMove
    value: 'true'
  - key: performance-unnecessary-value-param.AllowedTypes
    value: ''

  # ---------------------------------------------------------------------------
  # cppcoreguidelines overrides
  # ---------------------------------------------------------------------------
  - key: cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor
    value: 'true'
  - key: cppcoreguidelines-special-member-functions.AllowMissingMoveFunctions
    value: 'false'
  - key: cppcoreguidelines-special-member-functions.AllowMissingMoveFunctionsWhenCopyIsDeleted
    value: 'true'
